{
  "name": "chilean-plate-validator",
  "version": "0.9.0",
  "description": "Simple chilean plate validator",
  "author": "Gabriel Galilea",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2020",
    "dev": "tsup src/index.ts --watch --dts --target es2020",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabo2151/chilean-plate-validator"
  },
  "keywords": [
    "patente",
    "plate",
    "Chile",
    "validator",
    "validar"
  ],
  "devDependencies": {
    "@types/jest": "~30.0.0",
    "jest": "~30.3.0",
    "jest-sonar-reporter": "~2.0.0",
    "ts-jest": "~29.4.9",
    "tsup": "~8.5.1",
    "typescript": "~6.0.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  }
}
